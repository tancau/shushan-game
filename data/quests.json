{
  "quests": [
    {
      "quest_id": "main_001",
      "name": "初入蜀山",
      "description": "你初到蜀山，听闻峨眉派正招收新弟子。前往峨眉山脚，寻找引路人。",
      "quest_type": "主线",
      "objectives": [
        {
          "objective_type": "探索",
          "target": "峨眉山脚",
          "required": 1,
          "description": "抵达峨眉山脚"
        },
        {
          "objective_type": "对话",
          "target": "引路人李青云",
          "required": 1,
          "description": "与引路人李青云交谈"
        }
      ],
      "rewards": {
        "cultivation": 100,
        "spirit_stones": 50,
        "karma": 5
      },
      "prerequisites": [],
      "giver_npc": "系统",
      "completer_npc": "引路人李青云",
      "dialogues": [
        {
          "dialogue_id": "main_001_d1",
          "speaker": "引路人李青云",
          "text": "小友，你便是新来的弟子吧？峨眉派乃是正道大派，若有机缘，不妨入我门下修行。",
          "choices": [
            {
              "text": "弟子愿入峨眉修行",
              "next_dialogue_id": "main_001_d2_a",
              "karma_change": 5
            },
            {
              "text": "我想再考虑一下",
              "next_dialogue_id": "main_001_d2_b",
              "karma_change": 0
            }
          ]
        },
        {
          "dialogue_id": "main_001_d2_a",
          "speaker": "引路人李青云",
          "text": "甚好！你且去后山修炼场，先习得基础功法，日后自有进益。"
        },
        {
          "dialogue_id": "main_001_d2_b",
          "speaker": "引路人李青云",
          "text": "无妨，你且在山中四处走走，若想明白了再来寻我。"
        }
      ],
      "story_chapter": 1,
      "time_limit": 0
    },
    {
